# Core
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Security
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
LOG_JSON=False
ENABLE_SECURITY_HEADERS=True
CORS_ORIGINS=http://localhost:5501
TRUST_PROXY_HEADERS=False
GLOBAL_RATE_LIMIT_ENABLED=True
GLOBAL_RATE_LIMIT_MAX_REQUESTS=240
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60

# Database
# Local SQLite fallback (default if DATABASE_URL is omitted)
# DATABASE_URL=sqlite:///data/gestormei.db

# PostgreSQL production profile
DATABASE_URL=postgresql://gestormei:gestormei_password@localhost:5432/gestormei

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=VendaMais
