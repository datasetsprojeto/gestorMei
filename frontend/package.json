{
  "name": "gestormei-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 5501",
    "build": "vite build",
    "preview": "vite preview --host --port 5501",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@playwright/test": "1.58.2",
    "eslint": "9.39.3",
    "globals": "15.14.0",
    "husky": "9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "15.5.2",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "vite": "6.4.1",
    "vitest": "3.0.5"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
